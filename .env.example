# Application
APP_ENV=development          # "development" or "production"
PORT=8080
APP_BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgres://user:password@localhost:5432/appdb?sslmode=disable
DB_MAX_CONNS=25

# JWT
JWT_SECRET=<at-least-32-bytes-of-random-secret-here>
JWT_ACCESS_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h

# Passwords
BCRYPT_COST=12
PASSWORD_MIN_LENGTH=8

# SMTP (required for email verification and password reset)
# Local dev: make dev starts smtp4dev automatically (SMTP on :2525, web UI on :5000)
SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=MyApp
